# SourceBrief alpha local deployment environment
# Copy to .env before running docker compose if you want to override defaults:
#   cp .env.example .env

# Host ports exposed by docker-compose.yml. API/web are reachable on the Docker
# host by default. Postgres/Redis are published on 127.0.0.1 only; use an
# explicit Compose override if you intentionally need remote DB/queue access.
SOURCEBRIEF_API_PORT=18000
SOURCEBRIEF_WEB_PORT=13000
SOURCEBRIEF_POSTGRES_PORT=55432
SOURCEBRIEF_REDIS_PORT=6380

# Postgres container settings
POSTGRES_USER=sourcebrief
POSTGRES_PASSWORD=sourcebrief
POSTGRES_DB=sourcebrief

# Service URLs used inside Compose containers
# DATABASE_URL is derived from POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB by docker-compose.yml.
# Override it only when intentionally pointing API/workers at a non-compose database.
# SOURCEBRIEF_DATABASE_URL=postgresql+psycopg://sourcebrief:sourcebrief@postgres:5432/sourcebrief
SOURCEBRIEF_REDIS_URL=redis://redis:6379/0
# If opening the web UI from another machine, add that browser-visible web
# origin here, e.g. http://10.10.70.17:13000. API/web health can pass while
# browser login fails if this list and NEXT_PUBLIC_API_BASE_URL disagree.
SOURCEBRIEF_CORS_ORIGINS=http://localhost:13000,http://127.0.0.1:13000,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3105,http://127.0.0.1:3105,http://localhost:3205,http://127.0.0.1:3205

# Local bootstrap admin. Change this password for any shared deployment.
SOURCEBRIEF_ADMIN_EMAIL=admin@sourcebrief.local
SOURCEBRIEF_ADMIN_PASSWORD=change-me-before-compose-up
SOURCEBRIEF_ADMIN_DISPLAY_NAME=SourceBrief Admin
SOURCEBRIEF_BOOTSTRAP_WORKSPACE_NAME=SourceBrief
SOURCEBRIEF_BOOTSTRAP_WORKSPACE_SLUG=sourcebrief
SOURCEBRIEF_BOOTSTRAP_PROJECT_NAME=Default Project

# Local development auth for CLI/tests only. The web UI uses email/password login.
SOURCEBRIEF_DEV_AUTH=false
SOURCEBRIEF_ALLOW_LOCAL_GIT=true

# Frontend -> API URL visible from the browser. This is build-time for Next.js;
# run `docker compose up -d --build` after changing it. For remote/self-host
# browsers, this must be the host/IP the browser can reach, not localhost.
NEXT_PUBLIC_API_BASE_URL=http://localhost:18000

# Default offline providers. These require no external services and are deterministic for tests/demos.
SOURCEBRIEF_EMBEDDING_PROVIDER=hashing
SOURCEBRIEF_EMBEDDING_MODEL=sourcebrief-hashing-v1
SOURCEBRIEF_EMBEDDING_NORMALIZED=true
SOURCEBRIEF_RERANK_PROVIDER=term-overlap
SOURCEBRIEF_RERANK_MODEL=sourcebrief-term-overlap-v1

# Optional provider-backed embedding/rerank settings.
# Supported embedding providers: http, openai, openai-compatible, huggingface, vllm, sglang.
# Supported rerank providers: http, huggingface, vllm, sglang.
# SourceBrief MVP storage expects 64-dimensional embeddings; provider endpoints must return that dimension.
# Set a deployment id whenever endpoint/model/backend changes so old vector namespaces are not silently reused.
# SOURCEBRIEF_EMBEDDING_PROVIDER=openai-compatible
# SOURCEBRIEF_EMBEDDING_MODEL=bge-small-64
# SOURCEBRIEF_EMBEDDING_ENDPOINT=http://embedding-service:8000/v1/embeddings
# SOURCEBRIEF_EMBEDDING_API_KEY=change-me
# SOURCEBRIEF_EMBEDDING_DEPLOYMENT_ID=local-vllm-bge-small-64
# SOURCEBRIEF_EMBEDDING_TIMEOUT=30
# SOURCEBRIEF_RERANK_PROVIDER=http
# SOURCEBRIEF_RERANK_MODEL=bge-reranker
# SOURCEBRIEF_RERANK_ENDPOINT=http://rerank-service:8000/rerank
# SOURCEBRIEF_RERANK_API_KEY=change-me
# SOURCEBRIEF_RERANK_TIMEOUT=30
