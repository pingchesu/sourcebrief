# ContextSmith alpha local deployment environment
# Copy to .env before running docker compose if you want to override defaults:
#   cp .env.example .env

# Host ports exposed by docker-compose.yml
CONTEXTSMITH_API_PORT=18000
CONTEXTSMITH_WEB_PORT=13000
CONTEXTSMITH_POSTGRES_PORT=55432
CONTEXTSMITH_REDIS_PORT=6380

# Postgres container settings
POSTGRES_USER=contextsmith
POSTGRES_PASSWORD=contextsmith
POSTGRES_DB=contextsmith

# Service URLs used inside Compose containers
# DATABASE_URL is derived from POSTGRES_USER/POSTGRES_PASSWORD/POSTGRES_DB by docker-compose.yml.
# Override it only when intentionally pointing API/workers at a non-compose database.
# CONTEXTSMITH_DATABASE_URL=postgresql+psycopg://contextsmith:contextsmith@postgres:5432/contextsmith
CONTEXTSMITH_REDIS_URL=redis://redis:6379/0
CONTEXTSMITH_CORS_ORIGINS=http://localhost:13000,http://127.0.0.1:13000

# Local bootstrap admin. Change this password for any shared deployment.
CONTEXTSMITH_ADMIN_EMAIL=admin@contextsmith.local
CONTEXTSMITH_ADMIN_PASSWORD=change-me-before-compose-up
CONTEXTSMITH_ADMIN_DISPLAY_NAME=ContextSmith Admin
CONTEXTSMITH_BOOTSTRAP_WORKSPACE_NAME=ContextSmith
CONTEXTSMITH_BOOTSTRAP_WORKSPACE_SLUG=contextsmith
CONTEXTSMITH_BOOTSTRAP_PROJECT_NAME=Default Project

# Local development auth for CLI/tests only. The web UI uses email/password login.
CONTEXTSMITH_DEV_AUTH=false
CONTEXTSMITH_ALLOW_LOCAL_GIT=true

# Frontend -> API URL visible from the browser. This is build-time for Next.js;
# run `docker compose up -d --build` after changing it.
NEXT_PUBLIC_API_BASE_URL=http://localhost:18000

# Default offline providers. These require no external services and are deterministic for tests/demos.
CONTEXTSMITH_EMBEDDING_PROVIDER=hashing
CONTEXTSMITH_EMBEDDING_MODEL=contextsmith-hashing-v1
CONTEXTSMITH_EMBEDDING_NORMALIZED=true
CONTEXTSMITH_RERANK_PROVIDER=term-overlap
CONTEXTSMITH_RERANK_MODEL=contextsmith-term-overlap-v1

# Optional provider-backed embedding/rerank settings.
# Supported embedding providers: http, openai, openai-compatible, huggingface, vllm, sglang.
# Supported rerank providers: http, huggingface, vllm, sglang.
# ContextSmith MVP storage expects 64-dimensional embeddings; provider endpoints must return that dimension.
# Set a deployment id whenever endpoint/model/backend changes so old vector namespaces are not silently reused.
# CONTEXTSMITH_EMBEDDING_PROVIDER=openai-compatible
# CONTEXTSMITH_EMBEDDING_MODEL=bge-small-64
# CONTEXTSMITH_EMBEDDING_ENDPOINT=http://embedding-service:8000/v1/embeddings
# CONTEXTSMITH_EMBEDDING_API_KEY=change-me
# CONTEXTSMITH_EMBEDDING_DEPLOYMENT_ID=local-vllm-bge-small-64
# CONTEXTSMITH_EMBEDDING_TIMEOUT=30
# CONTEXTSMITH_RERANK_PROVIDER=http
# CONTEXTSMITH_RERANK_MODEL=bge-reranker
# CONTEXTSMITH_RERANK_ENDPOINT=http://rerank-service:8000/rerank
# CONTEXTSMITH_RERANK_API_KEY=change-me
# CONTEXTSMITH_RERANK_TIMEOUT=30
